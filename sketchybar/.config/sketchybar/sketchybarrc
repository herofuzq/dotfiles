#!/usr/bin/env lua

-- Load the sketchybar-package and prepare the helper binaries
package.loaded["helpers"] = nil
require("helpers")

local settings = require("settings")
local toggle_height = settings.height + 5
local toggle_cmd = table.concat({
	'pidfile="/tmp/sketchybar_toggle.pid"',
	'heightfile="/tmp/sketchybar_toggle.height"',
	'height="' .. tostring(toggle_height) .. '"',
	'old="$(cat "$pidfile" 2>/dev/null)"',
	'case "$old" in ""|*[!0-9]*) old="" ;; esac',
	'current_height="$(cat "$heightfile" 2>/dev/null)"',
	'if [ -n "$old" ] && kill -0 "$old" 2>/dev/null && [ "$current_height" = "$height" ]; then exit 0; fi',
	'if [ -n "$old" ]; then kill "$old" 2>/dev/null; else pkill -x sketchybar-toggle 2>/dev/null; fi',
	'sketchybar-toggle --trigger-zone 5 --menu-bar-height "$height" --debounce 150 >/dev/null 2>&1 &',
	'echo $! > "$pidfile"',
	'echo "$height" > "$heightfile"',
}, "\n")
os.execute(toggle_cmd)

require("init")
