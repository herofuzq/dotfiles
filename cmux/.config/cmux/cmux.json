{
  "$schema": "https://raw.githubusercontent.com/manaflow-ai/cmux/main/web/data/cmux.schema.json",
  "schemaVersion": 1,

  // This file uses JSONC. Only explicitly set keys override defaults.
  // Remove a key to fall back to the value saved in Settings.

  "app": {
    "iMessageMode": true
  },

  "terminal": {
    "showScrollBar": false
  },

  "sidebarAppearance": {
    "matchTerminalBackground": true
  },

