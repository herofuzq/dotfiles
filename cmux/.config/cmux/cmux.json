  "shortcuts": {
    "bindings": {
      // ── tmux C-a prefix mappings ──────────────────────────

      // pane / surface
      "newSurface":             ["ctrl+a", "c"],
      "splitRight":             ["ctrl+a", "="],
      "splitDown":              ["ctrl+a", "-"],
      "closeTab":               ["ctrl+a", "x"],

      // navigation (vim-tmux-navigator C-h/j/k/l style)
      "focusLeft":              ["ctrl+a", "h"],
      "focusDown":              ["ctrl+a", "j"],
      "focusUp":                ["ctrl+a", "k"],
      "focusRight":             ["ctrl+a", "l"],

      // switch surfaces
      "nextSurface":            ["ctrl+a", "n"],
      "prevSurface":            ["ctrl+a", "p"],

      // zoom / copy mode
      "toggleSplitZoom":        ["ctrl+a", "z"],
      "toggleTerminalCopyMode": ["ctrl+a", "["],

      // rename
      "renameTab":              ["ctrl+a", ","],
      "renameWorkspace":        ["ctrl+a", "$"],

      // workspace / palette
      "goToWorkspace":          ["ctrl+a", "w"],
      "commandPalette":         ["ctrl+a", ":"],

      // reload (your tmux: bind R source-file ...)
      "reloadConfiguration":    ["ctrl+a", "r"],

      // ── vim-tmux-navigator direct bindings ────────────────
      // no prefix — same muscle memory as tmux:
      //   C-h=left  C-j=down  C-k=up  C-l=right
      // note: only override these if they don't conflict
      // with your terminal workflow. comment out to disable.
      // "focusLeft":  "ctrl+h",
      // "focusDown":  "ctrl+j",
      // "focusUp":    "ctrl+k",
      // "focusRight": "ctrl+l"
    }
  }
