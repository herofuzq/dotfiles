#h ------ -------------------------------------------- #
# Shell
# -------------------------------------------------- #
shell-integration-features = cursor,sudo,title,ssh-env,ssh-terminfo
initial-command = /bin/zsh -c "$HOME/.config/fastfetch/pokemon.sh; exec /bin/zsh -l"
# -------------------------------------------------- #
# Macos
# -------------------------------------------------- #
macos-titlebar-style          = transparent
macos-titlebar-proxy-icon     = visible
macos-window-buttons          = visible
macos-window-shadow           = true
macos-option-as-alt           = true
macos-auto-secure-input       = true
macos-secure-input-indication = true
# -------------------------------------------------- #
# Font
# -------------------------------------------------- #
font-family = JetBrains Maple Mono
font-thicken = true
font-thicken-strength = 128
font-size = 16
# -------------------------------------------------- #
# Custom 
# -------------------------------------------------- #
theme = Catppuccin Mocha
background-opacity      = 1
background-blur         = 0
mouse-hide-while-typing = true

# split pane dimming — unfocused panes darken to show active one
unfocused-split-opacity = 0.50
unfocused-split-fill    = 181825
split-divider-color     = 45475a

# padding — compact
window-padding-x        = 4
window-padding-y        = 4
window-padding-balance  = true

# splits/tabs inherit CWD
split-inherit-working-directory  = true
window-inherit-working-directory = true

window-decoration       = auto
window-theme            = auto
window-colorspace       = srgb
window-step-resize      = false
window-width            = 150
window-height           = 50
window-new-tab-position = current
focus-follows-mouse     = false
# -------------------------------------------------- #
# Shader 
# -------------------------------------------------- #
custom-shader = "shaders/cursor_warp.glsl"
custom-shader = "shaders/ripple_cursor.glsl"
# -------------------------------------------------- #
# Clipboard 
# -------------------------------------------------- #
clipboard-read                 = ask
clipboard-write                = allow
clipboard-paste-protection     = true
clipboard-trim-trailing-spaces = true
# -------------------------------------------------- #
# Startup
# -------------------------------------------------- #
env = LANG=zh_CN.UTF-8
# -------------------------------------------------- #
# Quick_drop
# -------------------------------------------------- #
keybind = global:ctrl+alt+cmd+q=toggle_quick_terminal
quick-terminal-position       = top
quick-terminal-size           = 45%
quick-terminal-screen         = mouse
quick-terminal-space-behavior = move
quick-terminal-autohide       = true
